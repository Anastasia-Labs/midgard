L1_PROVIDER=Kupmios
L1_BLOCKFROST_API_URL=
L1_BLOCKFROST_KEY=
L1_BLOCKFROST_KEY_FALLBACK=
L1_OGMIOS_KEY=
L1_KUPO_KEY=
# When using docker-compose.kupmios.yaml, these are overridden to the in-stack
# Ogmios and Kupo endpoints automatically.
L1_OPERATOR_SEED_PHRASE=
L1_OPERATOR_SEED_PHRASE_FOR_MERGE_TX=
L1_REFERENCE_SCRIPT_SEED_PHRASE=
L1_REFERENCE_SCRIPT_ADDRESS=
# Production-safe wallet topology requires distinct addresses for the operator,
# merge, and reference-script roles. Do not point these three roles at the same
# wallet.
NETWORK=Preprod
# Optional local Cardano stack for docker-compose.kupmios.yaml.
# NETWORK is the source of truth. These defaults currently match
# NETWORK=Preprod, and the Mithril bootstrap will fail fast if they drift.
CARDANO_NODE_IMAGE_TAG=10.6.2
OGMIOS_IMAGE_TAG=latest
KUPO_IMAGE_TAG=latest
MITHRIL_CLIENT_IMAGE_TAG=latest
MITHRIL_AGGREGATOR_ENDPOINT=https://aggregator.release-preprod.api.mithril.network/aggregator
MITHRIL_GENESIS_VERIFICATION_KEY_URL=https://raw.githubusercontent.com/input-output-hk/mithril/main/mithril-infra/configuration/release-preprod/genesis.vkey
MITHRIL_ANCILLARY_VERIFICATION_KEY_URL=https://raw.githubusercontent.com/input-output-hk/mithril/main/mithril-infra/configuration/release-preprod/ancillary.vkey
MITHRIL_SNAPSHOT_DIGEST=latest
KUPO_SNAPSHOT_RELEASE_TAG=v2.8
# Optional override for the official Kupo snapshot bootstrap.
KUPO_SNAPSHOT_URL=
KUPO_SNAPSHOT_MD5=d67726a64b5714fdd1dd68790762659e
OGMIOS_PORT=1337
KUPO_PORT=1442
CARDANO_NODE_EKG_PORT=12788
CARDANO_NODE_PROM_PORT=12798
PORT=3000
MIDGARD_NODE_URL=http://127.0.0.1:3000
WAIT_BETWEEN_BLOCK_COMMITMENT=1000
WAIT_BETWEEN_BLOCK_CONFIRMATION=10000
BLOCK_CONFIRMATION_AWAIT_TIMEOUT_MS=12000
BLOCK_CONFIRMATION_AWAIT_RETRIES=1
UNCONFIRMED_BLOCK_MAX_AGE_MS=180000
WAIT_BETWEEN_MERGE_TXS=10000
MIN_QUEUE_LENGTH_FOR_MERGING=2
MIN_FEE_A=10
MIN_FEE_B=10
WAIT_BETWEEN_DEPOSIT_UTXO_FETCHES=10000
WAIT_BETWEEN_RETENTION_SWEEPS=3600000
HUB_ORACLE_ONE_SHOT_TX_HASH=
HUB_ORACLE_ONE_SHOT_OUTPUT_INDEX=-1
OPERATOR_REQUIRED_BOND_LOVELACE=5000000
OPERATOR_SLASHING_PENALTY_LOVELACE=200000
RUN_GENESIS_ON_STARTUP=false
ADMIN_API_KEY=
MAX_SUBMIT_QUEUE_SIZE=10000
MAX_SUBMIT_TX_CBOR_BYTES=32768
READINESS_MAX_HEARTBEAT_AGE_MS=120000
READINESS_MAX_QUEUE_DEPTH=10000
RETENTION_DAYS=0
PROM_METRICS_PORT=9464
OLTP_EXPORTER_URL="http://tempo:4318/v1/traces"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=midgard
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
LEDGER_MPT_DB_PATH=midgard-ledger-mpt-db
MEMPOOL_MPT_DB_PATH=midgard-mempool-mpt-db
TESTNET_GENESIS_WALLET_SEED_PHRASE_A="panther fly crawl express smile lend company blue slogan dawn wall tip angle tomorrow battle myth category vanish misery ocean include salon wood rail"
TESTNET_GENESIS_WALLET_SEED_PHRASE_B="second salad helmet humble left noise inform person swamp surround twice animal fitness sing laundry saddle stove guess cabin rural kidney reject oil fee"
TESTNET_GENESIS_WALLET_SEED_PHRASE_C="cactus chalk grit reopen true slight whale sand law sibling silver fringe cement twist process bracket history leopard churn federal coral three hockey fossil"
USER_WALLET="cupboard digital guitar diesel critic will afford salon game dolphin phrase baby dad urban machine barely rack acoustic blood vote misery enemy salute depart"
USER_SEED_PHRASE="cupboard digital guitar diesel critic will afford salon game dolphin phrase baby dad urban machine barely rack acoustic blood vote misery enemy salute depart"
